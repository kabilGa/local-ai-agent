# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=change-me-strong-key

# ── Embeddings ────────────────────────────────────────────────────────────────
# Leave empty to use fastembed locally (no server needed)
# Set to http://localhost:8080 to use a HuggingFace TEI server
EMBEDDING_MODEL_URL=
EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-code
EMBEDDING_MODEL_VERSION=v1-0

# ── Reranker (optional) ───────────────────────────────────────────────────────
RERANKER_URL=http://localhost:8081
RERANKER_ENABLED=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:change-me@localhost:6379
REDIS_PASSWORD=change-me

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_WORKSPACE=/tmp/rag-repos
WEBHOOK_SECRET=change-me-webhook-secret

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_SCANNER_ENABLED=true
GITLEAKS_BINARY=gitleaks

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.95
