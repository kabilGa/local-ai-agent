FROM python:3.12-slim

RUN pip install --no-cache-dir \
    pytest==8.2.2 \
    flake8==7.1.0 \
    black==24.4.2 \
    bandit==1.7.9 \
    pip-audit==2.7.3

RUN groupadd --gid 10001 sandbox && \
    useradd --uid 10001 --gid sandbox --create-home --shell /bin/false sandbox

WORKDIR /workspace
USER sandbox