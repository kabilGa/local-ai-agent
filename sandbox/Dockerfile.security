FROM python:3.12-slim

RUN pip install --no-cache-dir \
    semgrep==1.75.0 \
    bandit==1.7.9 \
    detect-secrets==1.5.0 \
    pip-audit==2.7.3 \
    checkov==3.2.0

RUN groupadd --gid 10001 sandbox && \
    useradd --uid 10001 --gid sandbox --create-home --shell /bin/false sandbox

WORKDIR /workspace
USER sandbox